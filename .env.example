# Pflicht: mindestens 32 zufällige Zeichen
# Generieren: openssl rand -hex 32
JWT_SECRET=

# Kommasepariert, alle Origins von denen die Web-App geladen wird
# Beispiel: http://luxstage.local,http://192.168.1.100,https://luxstage.example.com
CORS_ORIGINS=

# Optional: KI-Features (Anthropic Claude)
ANTHROPIC_API_KEY=
